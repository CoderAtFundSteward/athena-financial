PORT=3002
CLIENT_URL=http://localhost:5280

# QuickBooks Online OAuth (Intuit Developer — same app can use sandbox or production)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_ENVIRONMENT=sandbox
# Must match an allowed Redirect URI on your Intuit app (include /api/integrations/quickbooks/callback)
QB_REDIRECT_URI=http://localhost:3002/api/integrations/quickbooks/callback

# Encrypt OAuth tokens at rest (set a long random string in production)
ENCRYPTION_KEY=

# Production: set to your real site origin(s), comma-separated if multiple.
# Example: https://athena.example.org,https://www.athena.example.org

# Supabase — required for QuickBooks OAuth on Vercel (serverless has no shared memory).
# Run supabase/migrations/001_quickbooks_oauth.sql in the Supabase SQL editor first.
SUPABASE_URL=
# Server-only; never expose to the browser, Vite, or the anon key client:
SUPABASE_SERVICE_ROLE_KEY=
